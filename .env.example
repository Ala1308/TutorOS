# =============================================================================
# TutorOS AI environment variables
# Copy to .env.local for local dev. Never commit real secrets.
# All variables are validated by lib/env.ts at boot.
# =============================================================================

# --- Database (Supabase Postgres) -------------------------------------------
# DATABASE_URL: app runtime — use Session Pooler (port 6543, ?pgbouncer=true)
# in production so serverless functions don't exhaust connections.
# DIRECT_URL: migrations / drizzle-kit — must be the Direct Connection (port 5432).
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Auth (Supabase) --------------------------------------------------------
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- AI providers (optional — runAgent reports unavailable if all empty) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Observability ----------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Background jobs (Inngest) ----------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Google Workspace -------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback
TOKEN_ENCRYPTION_KEY=

# --- Email (Resend, transactional) ------------------------------------------
# Optional. When empty, lib/email.sendEmail() no-ops in dev (logs a warning)
# and throws in prod. Get a key at https://resend.com (free tier: 100/day).
# Use onboarding@resend.dev for first-run testing; switch to a verified
# domain (e.g. noreply@yourdomain.com) before inviting real users.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- Voice (pluggable: none | vapi | elevenlabs | bland | retell | synthflow | lindy)
VOICE_PROVIDER=none
VAPI_API_KEY=
ELEVENLABS_API_KEY=
BLAND_API_KEY=
RETELL_API_KEY=
SYNTHFLOW_API_KEY=
LINDY_API_KEY=

# --- Defaults ---------------------------------------------------------------
DEFAULT_TIMEZONE=America/Montreal
DEFAULT_CURRENCY=CAD
