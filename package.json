{
  "name": "tutoros-ai",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.10.0 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:types": "supabase gen types typescript --linked --schema public 2>/dev/null | awk '/^} as const$/{print; exit} {print}' > lib/db/supabase-types.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:setup": "tsx scripts/setup-test-db.ts",
    "eval": "tsx scripts/run-eval.ts",
    "seed:owner": "tsx scripts/seed-owner.ts",
    "dev:magic-link": "tsx scripts/dev-magic-link.ts",
    "dev:test-email": "tsx scripts/test-email.ts",
    "inngest:dev": "inngest-cli dev"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/google": "^1.2.0",
    "@ai-sdk/openai": "^1.3.0",
    "@hookform/resolvers": "^3.9.1",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "@tanstack/react-query": "^5.59.20",
    "@tanstack/react-table": "^8.20.5",
    "ai": "^4.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.36.4",
    "drizzle-zod": "^0.5.1",
    "googleapis": "^144.0.0",
    "inngest": "^3.27.0",
    "langfuse": "^3.30.0",
    "lucide-react": "^0.460.0",
    "next": "^15.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.2",
    "resend": "^6.12.2",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.28.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.0",
    "msw": "^2.6.5",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.14",
    "tinyglobby": "^0.2.16",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
